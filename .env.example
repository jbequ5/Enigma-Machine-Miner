# .env.example - Copy to .env and fill in your keys
# Enigma Machine Miner - Hardened Launch Version

# ==================== PRIMARY COMPUTE ====================
# Chutes (recommended for production)
CHUTES_API_KEY=chutes_...
OPENROUTER_API_KEY=sk-or-...

# Local GPU fallback (optional)
# No key needed if running locally with vLLM

# ==================== OPTIONAL EXTERNAL APIS ====================
# Only needed if you enable specific research/reflection features

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ==================== BITTENSOR / WALLET ====================
# Optional - used for miner registration and submissions
WALLET_NAME=default
WALLET_HOTKEY=default

# ==================== GITHUB (for ToolHunter) ====================
GITHUB_TOKEN=ghp_...

# ==================== ORIGINTRAIL DKG (optional, read-only) ====================
# Only used if you manually enable public DKG context fetching
DKG_GATEWAY=https://gateway.origintrail.io

# ==================== NOTES ====================
# - Most features now run through Chutes + vLLM/Quasar
# - External APIs (OpenAI/Anthropic) are only used optionally for reflection/exploration
# - Runtime tool creation is disabled for safety
# - Quasar Attention and dynamic swarm are enabled by default in the UI


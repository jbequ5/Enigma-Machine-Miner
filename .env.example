# .env.example - Copy to .env and fill in your keys

# Required for ScienceClaw, AI-Researcher, HyperAgent

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Optional: Chutes-specific (if you use Chutes SDK)

CHUTES_API_KEY=...

# Bittensor wallet (optional - can also use config/miner.yaml)

WALLET_NAME=default
WALLET_HOTKEY=default
